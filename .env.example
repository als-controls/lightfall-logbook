# lucid-logbook environment configuration
# Copy to /opt/lucid-logbook/.env and edit

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Database (SQLite default, or use PostgreSQL)
# DATABASE_URL=sqlite+aiosqlite:///./logbook.db
# DATABASE_URL=postgresql+asyncpg://lucid:password@localhost:5432/logbook

# Keycloak auth (when enabled)
# KEYCLOAK_URL=https://keycloak.example.com
# KEYCLOAK_REALM=als
# KEYCLOAK_CLIENT_ID=lucid-logbook

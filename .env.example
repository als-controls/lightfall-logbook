# lightfall-logbook environment configuration
# Copy to /opt/lightfall-logbook/.env and edit

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Database — async SQLAlchemy URL
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///./logbook.db
# PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://lightfall:password@localhost:5432/logbook

# Keycloak auth (leave unset to disable — dev mode uses X-User-Id header)
# KEYCLOAK_URL=https://keycloak.example.com
# KEYCLOAK_REALM=als
# KEYCLOAK_CLIENT_ID=lightfall-logbook
# KEYCLOAK_AUDIENCE=  (optional, skips audience verification if empty)
